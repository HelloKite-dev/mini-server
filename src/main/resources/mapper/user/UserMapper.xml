<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.seoyeon.mini_server.user.dao.UserDao">

	<insert id="insertUser" parameterType="com.seoyeon.mini_server.user.dto.UserRequestDto">
		INSERT INTO USERS (USER_ID, USER_PW, USER_NM, USER_EMAIL, REG_DT)
		VALUES (#{userId}, #{userPw}, #{userNm}, #{userEmail}, NOW())
	</insert>

	<select id="selectUser" parameterType="String" resultType="com.seoyeon.mini_server.user.dto.UserResponseDto">
		SELECT USER_ID,
			   USER_NM,
			   USER_EMAIL,
			   REG_DT
		FROM USERS
		WHERE USER_ID = #{userId}
	</select>

	<!-- <resultMap id="userLoginResultMap" type="com.seoyeon.mini_server.user.dto.UserRequestDto">
		<id property="userId" column="USER_ID"/>
		<result property="userPw" column="USER_PW"/>
	</resultMap> -->

	<select id="selectUserForLogin" parameterType="String" resultType="com.seoyeon.mini_server.user.dto.UserRequestDto">
		SELECT USER_ID,
			USER_PW,
			USER_NM
		FROM USERS
		WHERE USER_ID = #{userId}
	</select>
</mapper>